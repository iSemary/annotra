# HTTP port for local uvicorn server.
API_PORT=8006

# development|production
ENVIRONMENT=development

# PostgreSQL connection for SQLAlchemy async (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://annotra:annotra@localhost:15432/annotra

# HS256 signing key for access JWTs. Must be at least 32 characters.
# Generate e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated browser origins allowed for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Refresh cookie gets Secure flag. Use true in production
COOKIE_SECURE=false

# When false, login skips 2FA and the UI hides 2FA
TWO_FACTOR_ENABLED=false

# --- Optional --- #
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_COMPANY_NAME=Annotra
DEFAULT_ADMIN_FULL_NAME=Super Admin
DEFAULT_ADMIN_PHONE=+15551234567

# Annotation pipeline: inline|immediate (same request), background|deferred|async (after response),
# external|queue|worker (Celery worker + Redis).
ANNOTATION_ASSET_PIPELINE_MODE=inline

# Redis / Celery (required for external|queue|worker). CELERY_BROKER_URL defaults to REDIS_URL.
REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://
# CELERY_RESULT_BACKEND=

ML_OFFLINE=false

# Hugging Face token (only used when ML_OFFLINE=false). Ignored when ML_OFFLINE=true.
HF_TOKEN=

# Audio: transformers (default) or faster_whisper (CTranslate2; use with local WHISPER_MODEL_ID path + ML_OFFLINE).
WHISPER_ENGINE=transformers

# Skip real model inference (fast dev); still writes placeholder annotations.
ML_PIPELINE_DRY_RUN=false

SAM2_MODEL_ID=facebook/sam2-hiera-large
SAM2_POINT_GRID_STRIDE=64
SAM2_MAX_MASKS=32
WHISPER_MODEL_ID=openai/whisper-large-v3
VIDEO_MAX_FRAMES=120
MASK3D_POINT_SAMPLE_COUNT=65536
MASK3D_MIN_CLUSTER_POINTS=80