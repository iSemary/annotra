# HTTP port for local uvicorn server.
API_PORT=8006

# development|production
ENVIRONMENT=development

# PostgreSQL connection for SQLAlchemy async (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://annotra:annotra@localhost:15432/annotra

# HS256 signing key for access JWTs. Must be at least 32 characters.
# Generate e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated browser origins allowed for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Refresh cookie gets Secure flag. Use true in production
COOKIE_SECURE=false

# When false, login skips 2FA and the UI hides 2FA
TWO_FACTOR_ENABLED=false

# --- Optional --- #
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_COMPANY_NAME=Annotra
DEFAULT_ADMIN_FULL_NAME=Super Admin
DEFAULT_ADMIN_PHONE=+15551234567

# ANNOTATION_ASSET_PIPELINE_MODE — inline|immediate: 
ANNOTATION_ASSET_PIPELINE_MODE=inline
