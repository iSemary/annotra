  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8006" },
    { "key": "access_token", "value": "" },
    { "key": "project_id", "value": "" },
    { "key": "media_id", "value": "" },
    { "key": "annotation_asset_id", "value": "" },
    { "key": "annotation_id", "value": "" },
    { "key": "dataset_media_id_a", "value": "" },
    { "key": "dataset_media_id_b", "value": "" },
