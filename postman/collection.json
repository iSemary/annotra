{
  "info": {
    "name": "Annotra API",
    "description": "SaaS-based multimodal annotation platform designed for managing and labeling complex datasets including images, videos, and audio.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8006" },
    { "key": "access_token", "value": "" },
    { "key": "project_id", "value": "" },
    { "key": "media_id", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "role_id", "value": "" },
    { "key": "permission_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.data && j.data.access_token) {",
                  "  pm.environment.set('access_token', j.data.access_token);",
                  "  pm.collectionVariables.set('access_token', j.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Owner User\",\n  \"company_name\": \"Acme Inc\",\n  \"email\": \"owner@example.com\",\n  \"phone\": \"+12025550199\",\n  \"password\": \"password123\",\n  \"confirm_password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.data && j.data.access_token) {",
                  "  pm.environment.set('access_token', j.data.access_token);",
                  "  pm.collectionVariables.set('access_token', j.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/dashboard/summary"
          }
        },
        {
          "name": "Media list (superuser)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/dashboard/media?page=1&per_page=10&kind=all"
          }
        }
      ]
    },
    {
      "name": "Media",
      "item": [
        {
          "name": "Upload file",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "const d = j.data;",
                  "if (d && d.id) {",
                  "  pm.collectionVariables.set('media_id', d.id);",
                  "  if (pm.environment) pm.environment.set('media_id', d.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{base_url}}/api/v1/media/upload"
          }
        },
        {
          "name": "Upload bulk",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{base_url}}/api/v1/media/upload/bulk"
          }
        },
        {
          "name": "Get media",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/media/{{media_id}}"
          }
        },
        {
          "name": "Delete media",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/media/{{media_id}}"
          }
        }
      ]
    },
    {
      "name": "Users",
