{
  "info": {
    "name": "Annotra API",
    "description": "SaaS-based multimodal annotation platform for images, video, audio, datasets, and 3D models (glTF/GLB and other stored formats). Upload model media first, then create a model_3d annotation asset with primary_media_id.",
