            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Doe (updated)\",\n  \"phone\": \"+12025550201\"\n}"
            },
            "url": "{{base_url}}/api/v1/users/{{user_id}}"
          }
        },
        {
          "name": "Patch user role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role_id\": \"{{role_id}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/users/{{user_id}}/role"
          }
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/users/{{user_id}}"
          }
        }
      ]
