                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"+12025550200\",\n  \"password\": \"password123\",\n  \"role_id\": \"{{role_id}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/users"
          }
        },
        {
          "name": "Get user",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
