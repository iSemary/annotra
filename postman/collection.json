            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "const items = j.data && j.data.items;",
                  "if (items && items.length) {",
                  "  pm.collectionVariables.set('user_id', items[0].id);",
                  "  if (pm.environment) pm.environment.set('user_id', items[0].id);",
