{
  "info": {
    "name": "Annotra API",
    "description": "SaaS-based multimodal annotation platform designed for managing and labeling complex datasets including images, videos, and audio.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8006" },
    { "key": "access_token", "value": "" },
    { "key": "project_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.data && j.data.access_token) {",
                  "  pm.environment.set('access_token', j.data.access_token);",
                  "  pm.collectionVariables.set('access_token', j.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Owner User\",\n  \"company_name\": \"Acme Inc\",\n  \"email\": \"owner@example.com\",\n  \"phone\": \"+12025550199\",\n  \"password\": \"password123\",\n  \"confirm_password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.data && j.data.access_token) {",
                  "  pm.environment.set('access_token', j.data.access_token);",
                  "  pm.collectionVariables.set('access_token', j.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/dashboard/summary"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/users?page=1&page_size=10"
          }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"+12025550200\",\n  \"password\": \"password123\",\n  \"role_id\": \"REPLACE_WITH_ROLE_UUID\"\n}"
            },
            "url": "{{base_url}}/api/v1/users"
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "List roles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/roles?page=1&page_size=10"
          }
        }
      ]
    },
    {
      "name": "Permissions",
      "item": [
        {
          "name": "List permissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/permissions?page=1&page_size=10"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List projects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/projects?page=1&per_page=10"
          }
        },
        {
          "name": "Create project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.data && j.data.id) {",
                  "  pm.environment.set('project_id', j.data.id);",
                  "  pm.collectionVariables.set('project_id', j.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sample project\",\n  \"description\": \"Created from Postman\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{base_url}}/api/v1/projects"
          }
        },
        {
          "name": "Get project",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/projects/{{project_id}}"
          }
        },
        {
          "name": "Update project",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sample project (updated)\",\n  \"description\": \"Updated description\",\n  \"status\": \"archived\"\n}"
            },
            "url": "{{base_url}}/api/v1/projects/{{project_id}}"
          }
        },
        {
          "name": "Delete project",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/v1/projects/{{project_id}}"
          }
        }
      ]
    }
  ]
}
